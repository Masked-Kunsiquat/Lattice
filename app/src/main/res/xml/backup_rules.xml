<?xml version="1.0" encoding="utf-8"?>
<!--
  Legacy full-backup rules (API < 31).  API 31+ uses data_extraction_rules.xml instead.
  See https://developer.android.com/guide/topics/data/autobackup

  Mirrors the exclusion list in data_extraction_rules.xml — see that file for rationale.
-->
<full-backup-content>
    <exclude domain="sharedpref" path="cloud_credentials.xml"/>
    <exclude domain="sharedpref" path="lattice_db_prefs.xml"/>
    <exclude domain="database"   path="lattice.db"/>
</full-backup-content>
